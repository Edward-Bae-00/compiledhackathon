{
  "name": "fraud-investigator-copilot",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "dev:api": "cd apps/api && .venv/bin/uvicorn fraudcopilot.app:app --reload",
    "build:web": "npm run build --workspace apps/web",
    "dev": "npm run dev:web",
    "dev:web": "npm run dev --workspace apps/web",
    "lint:web": "npm run lint --workspace apps/web",
    "test": "npm run test:web && npm run test:api",
    "test:api": "cd apps/api && .venv/bin/pytest -q",
    "test:web": "npm run test --workspace apps/web"
  }
}
